# Copy to .env and fill in. NEVER commit the real .env.
EXCHANGE_ID=binance
USE_SANDBOX=True
EXCHANGE_API_KEY=your-testnet-key-here
EXCHANGE_API_SECRET=your-testnet-secret-here
RISK_TOTAL_DRAWDOWN_LIMIT=0.03
ORDER_TIMEOUT_S=2.0
KRONOS_REPO_PATH=./Kronos
CONFLUENCE_MIN_VOTES=2
META_FILTER_MODE=shadow
META_MIN_PWIN=0.5

# --- Multi-variant data farm (one bot per folder, per testnet account) ---
# Identity stamped on every journaled trade. Kelly replay and the dashboard
# only ever read their own variant. Default: prod.
VARIANT=prod
# Set false to compute+journal a gate without enforcing it (harvester).
REGIME_ENFORCE=true
CONFLUENCE_ENFORCE=true
# When set, every trade requests this fixed quote notional (USDT) instead
# of Kelly sizing. Leave unset for normal sizing.
#FIXED_TRADE_NOTIONAL=25
# Tuning knobs (defaults shown). Engine refuses
# DEAD_BAND_LOW < DEAD_BAND_HIGH <= EDGE_THRESHOLD violations at boot.
#REGIME_MIN_ADX=25
#EDGE_THRESHOLD=0.53
#DEAD_BAND_LOW=0.48
#DEAD_BAND_HIGH=0.52
# Bracket distances in ATR multiples + entry slippage gate (fractional).
# Walk-forward 2026-06-11 favoured TP 2.5 / SL 2.5 with ADX>30.
#TP_ATR_MULT=1.5
#SL_ATR_MULT=2.5
#SLIPPAGE_LIMIT=0.0005
